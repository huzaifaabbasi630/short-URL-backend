{
  "version": 2,
  "builds": [
    {
      "src": "src/index.ts",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "src/index.ts"
    }
  ],
  "env": {
    "REDIS_URL": "@redis_url",
    "REDIS_TOKEN": "@redis_token",
    "NODE_ENV": "production",
    "FRONTEND_URL": "@frontend_url"
  }
}
